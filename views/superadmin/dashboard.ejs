<%- include('../partials/head', {title: 'Super Admin Dashboard'}) %>
<div class="app-layout">
  <%- include('../partials/sidebar-superadmin') %>
  <div class="main-content">
    <header class="page-header">
        <button class="mobile-menu-btn" onclick="openSidebar()"><i class="bx bx-menu"></i></button>
      <div><div class="page-title">Super Admin Dashboard</div><div class="page-subtitle">System-wide overview</div></div>
    </header>
    <div class="page-body">
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-icon purple"><i class="bx bxs-building"></i></div><div><div class="stat-value" id="s-companies">—</div><div class="stat-label">Total Companies</div></div></div>
        <div class="stat-card"><div class="stat-icon green"><i class="bx bxs-check-circle"></i></div><div><div class="stat-value" id="s-active">—</div><div class="stat-label">Active Companies</div></div></div>
        <div class="stat-card"><div class="stat-icon orange"><i class="bx bxs-group"></i></div><div><div class="stat-value" id="s-users">—</div><div class="stat-label">Total Users</div></div></div>
        <div class="stat-card"><div class="stat-icon pink"><i class="bx bxs-bar-chart-square"></i></div><div><div class="stat-value" id="s-admins">—</div><div class="stat-label">Admins</div></div></div>
      </div>

      <div class="card">
        <div class="card-header"><span class="card-title"><i class="bx bxs-building"></i> Companies Overview</span><a href="/superadmin/companies" class="btn btn-ghost btn-sm">Manage</a></div>
        <div class="card-body">
          <div class="table-wrapper">
            <table>
              <thead><tr><th>Company</th><th>Industry</th><th>Email</th><th>Users</th><th>Status</th></tr></thead>
              <tbody id="companies-tbody"><tr><td colspan="5" style="text-align:center;padding:40px"><span class="spinner"></span></td></tr></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/api.js"></script>
<script>
async function loadDashboard() {
  try {
    const [stats, users] = await Promise.all([api('GET','/companies/stats'), api('GET','/users')]);
    document.getElementById('s-companies').textContent = stats.length;
    document.getElementById('s-active').textContent = stats.filter(c=>c.status==='active').length;
    document.getElementById('s-users').textContent = users.length;
    document.getElementById('s-admins').textContent = users.filter(u=>u.role==='admin').length;

    document.getElementById('companies-tbody').innerHTML = stats.length ? stats.map(c=>`<tr>
      <td><strong>${c.name}</strong></td>
      <td style="color:var(--text-secondary)">${c.industry||'—'}</td>
      <td style="font-size:13px">${c.email}</td>
      <td>${c.userCount}</td>
      <td>${statusBadge(c.status)}</td>
    </tr>`).join('') : '<tr><td colspan="5"><div class="empty-state"><div class="empty-icon"><i class="bx bxs-building"></i></div><p>No companies yet</p></div></td></tr>';
  } catch(e) { toast(e.message,'error'); }
}
loadDashboard();
</script>
</body></html>
